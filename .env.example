# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# ===========================================================================
# Supabase
# ---------------------------------------------------------------------------
# Find these in: Supabase Dashboard > Project Settings > API
# ===========================================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ===========================================================================
# Admin auth (the /admin dashboard)
# ---------------------------------------------------------------------------
# ADMIN_PASSWORD: the password used to log in at /admin/login
# ADMIN_SESSION_SECRET: random hex string (32+ bytes) used to sign session cookies
#   generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ===========================================================================
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-to-a-long-random-hex-string
